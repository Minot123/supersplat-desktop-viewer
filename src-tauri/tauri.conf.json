{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SuperSplat Desktop Viewer",
  "version": "0.1.17",
  "identifier": "com.antigravity.supersplatdesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "SuperSplat Desktop Viewer",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": []
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "fileAssociations": [
      {
        "ext": [
          "ply"
        ],
        "name": "3D Gaussian Splat Scene",
        "description": "SuperSplat Desktop Viewer Scene",
        "role": "Viewer"
      },
      {
        "ext": [
          "sog"
        ],
        "name": "SuperSplat Optimized Gaussian Scene",
        "description": "SuperSplat Desktop Viewer Scene",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
